timezone: "America/Phoenix"

poll_interval_minutes: 15

sleep:
  enabled: true
  start: "21:45"   # 9:45 PM
  end: "05:00"     # 5:00 AM
  banner_text: "Sleeping — updates resume in the morning"

deep_clean:
  enabled: true
  weekday: "Sunday"
  time: "03:30"

display:
  # Inky Impressions 13.3 is usually 1600x1200 landscape.
  # We'll render portrait by swapping and rotating.
  width: 1200
  height: 1600
  rotate_degrees: 90   # 0/90/180/270 depending on how you mount it
  saturation: 0.0      # optional; depends on Inky driver support
  border: "white"

calendars:
  google:
    enabled: true
    calendar_ids:
      - "primary"
    # Google Tasks are rendered as the "Reminders" region (incomplete tasks due
    # today or overdue). Requires the tasks.readonly OAuth scope — re-run the
    # Google sign-in flow if your existing token predates this.
    tasks_enabled: true
    task_list_allowlist: []  # empty means all task lists
  icloud:
    enabled: true
    calendar_name_allowlist: []  # empty means all discovered calendars

travel:
  enabled: false
  origin_address: "123 Main St, Springfield, IL"
  back_to_back_window_minutes: 30

weather:
  latitude: 33.4353   # Goodyear, AZ (default)
  longitude: -112.3582

# Over-the-air updates. When enabled, the inkycal-update systemd timer checks
# GitHub roughly hourly and, if this checkout is behind the tracked branch,
# pulls the new code and restarts the display — no SSH needed. Set enabled to
# false to freeze the currently installed version.
auto_update:
  enabled: true
  branch: "main"
