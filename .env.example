# iCloud CalDAV
ICLOUD_USERNAME="you@icloud.com"
ICLOUD_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # app-specific password

# Google Calendar OAuth
GOOGLE_CREDENTIALS_JSON="/opt/inkycal/secrets/google_credentials.json"
GOOGLE_TOKEN_JSON="/opt/inkycal/secrets/google_token.json"

# Optional OAuth callback settings (useful when authorizing from another device):
# GOOGLE_OAUTH_HOST="192.168.1.50"   # IP/host reachable from browser device
# GOOGLE_OAUTH_BIND_ADDR="0.0.0.0"   # listen on all interfaces
# GOOGLE_OAUTH_PORT="0"              # 0 = choose a free port automatically
