# iCloud CalDAV
ICLOUD_USERNAME="you@icloud.com"
ICLOUD_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # app-specific password

# Google Calendar OAuth
GOOGLE_CREDENTIALS_JSON="/opt/inkycal/secrets/google_credentials.json"
GOOGLE_TOKEN_JSON="/opt/inkycal/secrets/google_token.json"

# Optional OAuth callback port (set a fixed port if using SSH port forwarding):
# GOOGLE_OAUTH_PORT="8080"
