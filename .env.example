# iCloud CalDAV
ICLOUD_USERNAME="you@icloud.com"
ICLOUD_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # app-specific password

# Google Calendar OAuth
# The Pi only reads GOOGLE_TOKEN_JSON. Generate it off-device with
# scripts/google_auth.py and copy it to this path. See README.
GOOGLE_TOKEN_JSON="/opt/inkycal/secrets/google_token.json"
