[Unit]
Description=InkyCal - Periodically check GitHub for over-the-air updates

[Timer]
# Check shortly after boot, then roughly hourly. RandomizedDelaySec spreads the
# GitHub requests out so many Pis don't all fetch at the same instant.
OnBootSec=3min
OnUnitActiveSec=1h
RandomizedDelaySec=10min
Persistent=true

[Install]
WantedBy=timers.target
